{
  "name": "next-adapter-bun",
  "version": "0.3.0",
  "description": "Next.js deployment adapter for Bun with SQLite-based ISR caching",
  "license": "MIT",
  "type": "module",
  "bin": {
    "next-adapter-bun": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "b:js": "bun run scripts/build.ts",
    "b:types": "tsc --emitDeclarationOnly",
    "b:prepare": "bun run scripts/prepare-publish.ts",
    "build": "bun run b:js && bun run b:types && bun run b:prepare",
    "lint": "biome check --write . && tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=16.2.0"
  },
  "dependencies": {
    "sharp": ">=0.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "1.3.11",
    "next": "16.2.4",
    "typescript": "6.0.2"
  },
  "keywords": [
    "nextjs",
    "next",
    "adapter",
    "bun",
    "sqlite",
    "isr",
    "cache",
    "deployment",
    "standalone"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annexare/next-adapter-bun.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
